# Copy this file to .env for local use if desired.
# Do not commit real API keys.

# OpenAI-compatible providers
OPENAI_API_KEY=replace_with_your_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Gemini OpenAI-compatible API
GEMINI_API_KEY=replace_with_your_gemini_key

# Optional C2Rust/LLVM overrides for local installations
SAFEMAP_C2RUST_CLANG=/opt/llvm-14.0.6/bin/clang
SAFEMAP_C2RUST_RESOURCE_DIR=/opt/llvm-14.0.6/lib/clang/14.0.6
SAFEMAP_C2RUST_LIB_DIR=/opt/llvm-14.0.6/lib
